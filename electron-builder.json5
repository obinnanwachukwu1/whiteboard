// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.obinnanwachukwu.whiteboard",
  "asar": true,
  "productName": "Whiteboard",
  "npmRebuild": false,
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    // Native modules that need to be included unpacked
    "node_modules/onnxruntime-node/**/*",
    "node_modules/keytar/**/*",
    // Dependencies of native modules that electron-builder might miss with pnpm
    "node_modules/onnxruntime-common/**/*",
    "node_modules/adm-zip/**/*",
    "node_modules/global-agent/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/bin",
      "to": "bin",
      "filter": [
        "**/*"
      ]
    }
  ],
  "asarUnpack": [
    // Native .node binaries must be unpacked from asar
    "node_modules/onnxruntime-node/**/*.node",
    "node_modules/keytar/**/*.node"
  ],
  "mac": {
    "icon": "build/icons/mac/icon.icns",
    "target": [
      "dmg"
    ],
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}"
  },
  "win": {
    "icon": "build/icons/win/icon.ico",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "icon": "build/icons/png",
    "target": [
      "AppImage"
    ],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}
