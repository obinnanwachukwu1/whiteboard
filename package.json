{
  "name": "whiteboard",
  "productName": "Whiteboard",
  "description": "A fast, focused Canvas LMS client.",
  "author": "Obinna Nwachukwu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:fast": "CSC_IDENTITY_AUTO_DISCOVERY=false npm_config_build_from_source=false vite build && electron-builder --dir",
    "pack:dir": "tsc && vite build && electron-builder --dir",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier -w .",
    "test": "vitest run",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "pnpm": {
    "overrides": {
      "canvas": "3.2.1",
      "@isaacs/brace-expansion": "5.0.1",
      "seroval": "^1.4.1",
      "tar": "^7.5.7"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "keytar",
      "cpu-features",
      "ssh2",
      "onnxruntime-node",
      "sharp",
      "protobufjs"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.13.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/transformers": "^3.8.1",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@tanstack/react-router": "^1.131.28",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-underline": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@use-gesture/react": "^10.3.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.11.0",
    "docx-preview": "^0.3.1",
    "dompurify": "^3.2.6",
    "flexsearch": "^0.8.212",
    "form-data": "^4.0.5",
    "global-agent": "^3.0.0",
    "graphql": "^16.11.0",
    "jszip": "^3.10.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.540.0",
    "mammoth": "^1.11.0",
    "marked": "^12.0.2",
    "onnxruntime-common": "1.23.2",
    "onnxruntime-node": "^1.23.2",
    "pdfjs-dist": "^5.4.624",
    "postinstall": "^0.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unpdf": "^1.4.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@tanstack/router-devtools": "^1.131.28",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "autoprefixer": "^10.4.21",
    "electron": "^40.1.0",
    "electron-builder": "^26.6.0",
    "electron-builder-squirrel-windows": "26.6.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.2.2",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  },
  "main": "dist-electron/main.js"
}
